# Copy to .env (git-ignored) and fill in. Playwright loads it via the
# `dotenv` shim in playwright.config? No — export it, or use `env $(cat
# .env | xargs)`. Simplest: `set -a; . ./.env; set +a; npm test`.

# REQUIRED. A FULL-ACCESS Resend API key (read scope) for the account that
# sends rewindjs sign-in emails. A send-only key will 401 on the
# list-sent-emails call.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Email to log in as. Defaults to the seeded operator (an@rcho.dev), which
# is authorized to reach the app.rewindjs.com dashboard.
E2E_LOGIN_EMAIL=an@rcho.dev

# Targets. Defaults point at production.
E2E_APP_URL=https://app.rewindjs.com
E2E_AUTH_URL=https://auth.rewindjs.com

# Optional replay-spec overrides. The replay origin defaults to E2E_APP_URL
# with the `app.` label swapped for `replay.` (mirroring the dashboard's own
# derivation); the instance defaults to __auth__, whose logs the login flow
# itself just populated.
#E2E_REPLAY_URL=https://replay.rewindjs.com
#E2E_REPLAY_INSTANCE=__auth__
